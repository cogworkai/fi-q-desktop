{
  "name": "fi-q-desktop",
  "productName": "Fi Q Desktop",
  "description": "Fi Q: Personal finance; figured out",
  "version": "0.4.2",
  "gitCommit": "af3e4d5",
  "private": true,
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.3"
  },
  "scripts": {
    "electron": "electron .",
    "electron-build": "APPLE_KEYCHAIN_PROFILE=my-app-password-profile electron-builder build -m",
    "electron-build-mas": "APPLE_KEYCHAIN_PROFILE=my-app-password-profile electron-builder build --mac mas",
    "electron-build-win": "electron-builder build -w",
    "bump-build-number": "./scripts/bump_version.sh build",
    "bump-patch-version": "./scripts/bump_version.sh patch",
    "bump-minor-version": "./scripts/bump_version.sh minor",
    "bump-major-version": "./scripts/bump_version.sh major",
    "publish-app": "xcrun altool --upload-app --type osx --file \"release/mas-arm64/Fi Q.pkg\" -u desirejesus@hotmail.com -p @keychain:altoolcreds",
    "publish-gh-release": "./scripts/publish_release.sh",
    "release": "yarn bump-build-number && yarn electron-build-mas && yarn publish-app",
    "release-patch": "yarn bump-patch-version && yarn electron-build-mas && yarn publish-app",
    "release-major": "yarn bump-major-version && yarn electron-build-mas && yarn publish-app",
    "release-minor": "yarn bump-minor-version && yarn electron-build-mas && yarn publish-app"
  },
  "license": "MIT",
  "exports": "./app/main.js",
  "main": "./app/main.js",
  "type": "module",
  "build": {
    "buildVersion": "82",
    "productName": "Fi Q",
    "appId": "com.cogworkai.fiq",
    "artifactName": "${productName}.${ext}",
    "extends": null,
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "app/**"
    ],
    "extraResources": [
      {
        "from": "./server/dist/",
        "to": "lib/",
        "filter": [
          "**/**"
        ]
      }
    ],
    "mac": {
      "extendInfo": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "target": [
        {
          "target": "mas",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": true
    },
    "mas": {
      "entitlements": "entitlements.mas.plist",
      "entitlementsInherit": "entitlements.mas.inherit.plist",
      "hardenedRuntime": false,
      "provisioningProfile": "/Users/chris/Downloads/Fi_Q_MAS(1).provisionprofile"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-notarize": "^1.2.2"
  }
}